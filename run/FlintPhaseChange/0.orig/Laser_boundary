FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      Laser_boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    left
    {
        type fixedValue;
        value uniform -1.0;
    }
    right
    {
        type fixedValue;
        value uniform -1.0;
    }
    top
    {
        type fixedValue;
        value uniform 1.0;
    }
    bottom
    {
        type fixedValue;
        value uniform -1.0;
    }
    defaultFaces
    {
        type            empty;
    }
}

