FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     laserbeamFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;
//stopAt          nextWrite;

endTime         5;

deltaT          1e-5;

writeControl    adjustable;

writeInterval   0.05;

purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  yes;

maxDeltaT       2e-4;

maxCo           0.25;

maxAlphaCo      0.25;

maxAlphaDdt     2.3; // Check this

maxDi           25; // Check this


// ************************************************************************* //

OptimisationSwitches
{
    fileHandler collated;
}

functions
{
    divU
    {
        type            div;
        libs            (fieldFunctionObjects);

        writeControl    writeTime;
        writeFields     true;
        regionType      all;

        result          divU;

        field           phi;
    }

    maxValue
    {
        type            fieldMinMax;

        libs            (fieldFunctionObjects);

        log             true;

        writeControl    timeStep;

        mode       magnitude;

        fields (p_rgh U T divU);
    }
}