FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     icoReactingMultiphaseInterFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         0.5;

deltaT          1e-5;

writeControl    adjustable;

writeInterval   0.05;

purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  yes;

maxDeltaT       1;

maxCo           0.2;

maxAlphaCo      0.2;

maxAlphaDdt     2.3; // Check this

maxDi           25; // Check this

// ************************************************************************* //

DebugSwitches
{
    multiphaseInterSystem 1;
}

OptimisationSwitches
{
    fileHandler collated;
}

functions
{
    divU
    {
        type            div;
        libs            (fieldFunctionObjects);

        writeControl    writeTime;
        writeFields     true;
        regionType      all;

        result          divU;

        field           phi;
    }

    maxValue
    {
        type            fieldMinMax;

        libs            (fieldFunctionObjects);

        log             true;

        writeControl    writeTime;

        mode       magnitude;

        fields (p_rgh U T divU);
    }

    lineUniform
    {
        type            sets;

        libs            (sampling);

        writeControl    writeTime;

        interpolationScheme cellPointFace;

        setFormat       csv;

        fields          (alpha.liquid);

        sets
        (
            left
            {
                type            uniform;
                axis            distance;
                start           (1e-7 0.0 5e-5);
                end             (1e-7 5e-4 5e-5);
                nPoints         360;
            }

            right
            {
                type            uniform;
                axis            distance;
                start           (0.9999e-3 0.0 5e-5);
                end             (0.9999e-3 5e-4 5e-5);
                nPoints         360;
            }
        );
    }
}