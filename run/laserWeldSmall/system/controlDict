FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     icoReactingMultiphaseInterFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         30e-6;

deltaT          1e-8;

writeControl    adjustable;

writeInterval   1e-6;

purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  yes;

maxDeltaT       2e-8;

maxCo           0.2;

maxAlphaCo      0.2;

maxAlphaDdt     0.2; // Check this

maxDi           0.2; // Check this

libs 
(
    spheresToCell
);

DebugSwitches
{
    laserDTRM   1;
}

// ************************************************************************* //

OptimisationSwitches
{
    fileHandler collated;
}

functions
{
    divU
    {
        type            div;
        libs            (fieldFunctionObjects);

        writeControl    writeTime;
        writeFields     true;
        regionType      all;

        result          divU;

        field           phi;
    }

    maxValue
    {
        type            fieldMinMax;

        libs            (fieldFunctionObjects);

        log             true;

        writeControl    writeTime;

        mode       magnitude;

        fields (p_rgh U T divU);
    }
}