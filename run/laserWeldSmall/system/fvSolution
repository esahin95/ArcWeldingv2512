FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "alpha.*"
    {
        nAlphaCorr      1;
        nAlphaSubCycles 3;
        cAlphas         (
                            (liquid and gas)  1
                            (solid and gas) 1
                            (solid and liquid) 0
                        );

        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-08;
        relTol          0.0;
    }

    /*
    p_rgh
    {
        solver          GAMG;
        preconditioner  FDIC;
        smoother        DICGaussSeidel;
        tolerance       1e-9;
        relTol          0.02;

        cacheAgglomeration  yes;
        agglomerator        faceAreaPair;
        nCellsinCoursestLevel 100;
        maxIter         50;
    }
    */

    p_rgh
    {
        solver          PCG;
        preconditioner
        {
            preconditioner  GAMG;
            tolerance       1e-7;
            relTol          0;
            nVcycles        2;
            smoother        GaussSeidel;
        }
        tolerance       1e-09;
        relTol          0.02;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    "pcorr.*"
    {
        $p_rghFinal;
    }

    T
    {
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       1e-10;
        relTol          0.02;
    }

    TFinal
    {
        $T;
        relTol          0.0;
    }
}

PIMPLE
{
    momentumPredictor   no;
    nOuterCorrectors    1;
    nCorrectors         3;
    nNonOrthogonalCorrectors 1;

    pRefCell            0;
    pRefValue           1e5;
}

relaxationFactors
{
    equations
    {
        ".*"        1;
    }
}


