FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      alpha.liquid;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    zmax
    {
        type            inletOutlet;
        value           uniform 0;
        inletValue      uniform 0;
    }

    "(zmin|xmax)"
    {
        type            zeroGradient;
    }

    "(front|back)"
    {
        type            wedge;
    }
}


