FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties.liquid;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


thermoType
{
    type            heSolidThermo;
    mixture         pureMixture;
    transport       constIso;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        nMoles          1;
        molWeight       46.7;
    }
    equationOfState
    {
        rho             4430;
    }
    thermodynamics
    {
        Cp              820;
        Hf              -2.83e+5;
    }
    transport
    {
        kappa           27.5;
    }
}

// ************************************************************************* //