FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      phaseProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type    massTransferMultiphaseSystem;

phases  (solid liquid gas);

solid 
{
    type            pureStaticSolidPhaseModel;
}

liquid
{
    type            pureMovingPhaseModel;
}

gas
{
    type            pureMovingPhaseModel;
}

surfaceTension
(
    (gas and liquid)
    {
        type            constant;
        sigma           0.07;
    }
    (gas and solid)
    {
        type            constant;
        sigma           0.0;
    }
    (solid and liquid)
    {
        type            constant;
        sigma           0.0;
    }
);

interfacePorous
(
    (solid and liquid)
    {
        type            VollerPrakash;
        solidPhase      alpha.solid;
        Cu              1e6;
    }
);


massTransferModel
(
    (solid to liquid)
    {
        type            Lee;
        C               3.25e+6;
        Tactivate       1710;
    }
    (liquid to solid)
    {
        type            Lee;
        C               -0.75e+5;
        Tactivate       1710;
    }
);


